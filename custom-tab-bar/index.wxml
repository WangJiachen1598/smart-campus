<view class="tab-bar">
  <view
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{isTeacher ? teacherList : studentList}}"
    wx:key="pagePath"
    wx:for-index="index"
    data-index="{{index}}"
    bindtap="switchTab">
    <view class="tab-icon">{{item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>

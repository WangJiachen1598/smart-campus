.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.semester-selector {
  margin: -30rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-value {
  font-size: 28rpx;
  color: #1a73e8;
  font-weight: 500;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.summary-card {
  display: flex;
  align-items: center;
  margin: 0 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.total-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-right: 40rpx;
  border-right: 1rpx solid #f0f0f0;
}

.score-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a73e8;
}

.stats-grid {
  flex: 1;
  display: flex;
  justify-content: space-around;
  margin-left: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.section {
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.awards-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.award-item {
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.award-item:last-child {
  border-bottom: none;
}

.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.project-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.create-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-right {
  display: flex;
  align-items: center;
}

.score-tag {
  font-size: 36rpx;
  font-weight: 700;
  color: #4caf50;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.remark {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.status-approved {
  background: #e8f5e9;
  color: #4caf50;
}

.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-rejected {
  background: #ffebee;
  color: #f44336;
}

.empty-tip {
  padding: 80rpx 0;
  text-align: center;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
}

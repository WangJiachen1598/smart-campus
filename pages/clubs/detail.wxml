<view class="container" wx:if="{{clubInfo}}">
  <view class="club-header">
    <view class="cover" style="height: 300rpx; background: linear-gradient(135deg, #1a73e8, #0d47a1); display: flex; align-items: center; justify-content: center; color: white; font-size: 64rpx;">🎯</view>
    <view class="header-overlay">
      <view class="club-basic">
        <text class="club-name">{{clubInfo.name}}</text>
        <text class="tag tag-primary">{{clubInfo.category}}</text>
      </view>
      <view class="club-stats">
        <view class="stat-item">
          <text class="stat-value">{{clubInfo.memberCount}}</text>
          <text class="stat-label">成员</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{clubInfo.activityCount}}</text>
          <text class="stat-label">活动</text>
        </view>
      </view>
    </view>
  </view>

  <view class="tab-section">
    <scroll-view scroll-x class="tab-scroll">
      <view class="tab-list">
        <view class="tab-item {{currentTab === index ? 'active' : ''}}" 
              wx:for="{{tabs}}" wx:key="index"
              bindtap="onTabChange" data-index="{{index}}">
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="tab-content">
    <view class="content-section" wx:if="{{currentTab === 0}}">
      <view class="info-card">
        <view class="info-row">
          <text class="info-label">指导老师</text>
          <text class="info-value">{{clubInfo.teacher}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">社团负责人</text>
          <text class="info-value">{{clubInfo.leader}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">成立时间</text>
          <text class="info-value">{{clubInfo.createTime}}</text>
        </view>
      </view>

      <view class="section-title">社团简介</view>
      <view class="description">
        <text>{{clubInfo.description}}</text>
      </view>

      <view class="section-title">纳新要求</view>
      <view class="requirement-list">
        <view class="requirement-item" wx:for="{{clubInfo.requirements}}" wx:key="index">
          <text class="requirement-icon">✓</text>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="content-section" wx:if="{{currentTab === 1}}">
      <view class="member-grid">
        <view class="member-item" wx:for="{{members}}" wx:key="id">
          <view class="member-avatar" style="width: 80rpx; height: 80rpx; border-radius: 50%; background: linear-gradient(135deg, #1a73e8, #0d47a1); display: flex; align-items: center; justify-content: center; color: white; font-size: 32rpx;">👤</view>
          <text class="member-name">{{item.name}}</text>
          <text class="member-role">{{item.role}}</text>
        </view>
      </view>
    </view>

    <view class="content-section" wx:if="{{currentTab === 2}}">
      <view class="activity-timeline">
        <view class="timeline-item" wx:for="{{activities}}" wx:key="id" bindtap="goActivityDetail" data-id="{{item.id}}">
          <view class="timeline-marker {{item.status}}"></view>
          <view class="timeline-content">
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-meta">{{item.time}} · {{item.location}}</text>
            <view class="activity-footer">
              <text class="activity-count">签到 {{item.signInCount}} 人</text>
              <text class="tag {{item.status === 'upcoming' ? 'tag-primary' : 'tag-gray'}}">
                {{item.status === 'upcoming' ? '即将开始' : '已完成'}}
              </text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-bar">
    <button class="btn {{isJoined ? 'btn-secondary' : isApplied ? 'btn-outline' : 'btn-primary'}}" 
            bindtap="goApply" wx:if="{{!isJoined || !isApplied}}">
      {{isJoined ? '已加入' : isApplied ? '申请中' : '申请加入'}}
    </button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
</view>
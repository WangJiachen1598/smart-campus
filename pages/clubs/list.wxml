<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="搜索社团名称或简介" value="{{searchKeyword}}" bindinput="onSearch" bindconfirm="onSearch" />
    </view>
  </view>

  <view class="category-tabs">
    <scroll-view scroll-x class="scroll-view">
      <view class="tab-list">
        <view class="tab-item {{currentCategory === item.id ? 'active' : ''}}" 
              wx:for="{{categories}}" wx:key="id"
              bindtap="onSelectCategory" data-id="{{item.id}}">
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="club-list">
    <view class="club-card" wx:for="{{filteredClubs}}" wx:key="id">
      <view class="club-cover" style="background: linear-gradient(135deg, #1a73e8, #0d47a1); display: flex; align-items: center; justify-content: center;">
        <text style="font-size: 48rpx; color: #fff;">🎯</text>
      </view>
      <view class="club-content">
        <view class="club-header">
          <text class="club-name">{{item.name}}</text>
          <text class="tag tag-primary">{{item.categoryName}}</text>
        </view>
        <text class="club-desc">{{item.description}}</text>
        <view class="club-stats">
          <view class="stat-item">
            <view class="stat-icon" style="width: 32rpx; height: 32rpx; background: #1a73e8; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 20rpx;">👥</view>
            <text>{{item.memberCount}}人</text>
          </view>
          <view class="stat-item">
            <view class="stat-icon" style="width: 32rpx; height: 32rpx; background: #4caf50; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 20rpx;">📅</view>
            <text>{{item.activityCount}}活动</text>
          </view>
        </view>
        <view class="club-actions">
          <button class="apply-btn" bindtap="goApply" data-id="{{item.id}}" data-name="{{item.name}}">立即报名</button>
        </view>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />

<view class="container">
  <view class="form-card">
    <view class="section-title">基本信息</view>
    
    <view class="input-group">
      <view class="input-label">姓名 <text class="required">*</text></view>
      <input class="input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onInput" data-field="name" />
    </view>
    
    <view class="input-group">
      <view class="input-label">学号 <text class="required">*</text></view>
      <input class="input" type="number" placeholder="请输入10位学号" value="{{formData.studentId}}" bindinput="onInput" data-field="studentId" maxlength="10" />
    </view>
    
    <view class="input-group">
      <view class="input-label">手机号 <text class="required">*</text></view>
      <input class="input" type="number" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onInput" data-field="phone" maxlength="11" />
    </view>
    
    <view class="divider"></view>
    
    <view class="section-title">申请理由</view>
    <view class="input-group">
      <textarea class="textarea" placeholder="请说明您加入本社团的理由" value="{{formData.reason}}" bindinput="onInput" data-field="reason" maxlength="500" />
      <view class="char-count">{{formData.reason.length}}/500</view>
    </view>
  </view>
  
  <view class="footer-bar">
    <button class="btn btn-primary btn-block" bindtap="onSubmit" loading="{{loading}}" disabled="{{loading}}">
      提交申请
    </button>
  </view>
</view>

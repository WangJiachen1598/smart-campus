.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-icon {
  width: 36rpx;
  height: 36rpx;
  margin-left: 16rpx;
}

.category-tabs {
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.scroll-view {
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  padding: 16rpx 32rpx;
  margin: 0 10rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  white-space: nowrap;
}

.tab-item.active {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  color: #fff;
}

.club-list {
  padding: 30rpx;
}

.club-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.club-cover {
  width: 100%;
  height: 300rpx;
}

.club-content {
  padding: 24rpx;
}

.club-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.club-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.club-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.club-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.stat-item image {
  width: 32rpx;
  height: 32rpx;
}

.stat-item.hot {
  color: #ff6b6b;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-detail {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.header-actions {
  display: flex;
  align-items: center;
}

.message-badge {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-badge .icon {
  width: 48rpx;
  height: 48rpx;
}

.message-badge .badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4757;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.banner {
  height: 320rpx;
  margin: -60rpx 30rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(26, 115, 232, 0.3);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: transform 0.3s;
}

.action-icon:active {
  transform: scale(0.95);
}

.action-icon image {
  width: 56rpx;
  height: 56rpx;
}

.action-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.section {
  padding: 30rpx;
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a73e8;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.announcement-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.announcement-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.announcement-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.announcement-title.important {
  color: #f44336;
  font-weight: 500;
}

.announcement-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.activity-info {
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.activity-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.activity-status {
  display: flex;
  align-items: center;
}

.tag-gray {
  background: #f5f5f5;
  color: #999;
}

.teacher-section {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  border-radius: 20rpx;
  margin: 30rpx;
  padding: 30rpx;
}

.teacher-section .section-title {
  color: #f57c00;
  border-left-color: #f57c00;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.admin-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  transition: transform 0.3s;
}

.admin-item:active {
  transform: scale(0.95);
}

.admin-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.admin-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(26, 115, 232, 0.4);
  z-index: 100;
}

.fab image {
  width: 56rpx;
  height: 56rpx;
}

.fab text {
  font-size: 22rpx;
  color: #fff;
  margin-top: 4rpx;
}
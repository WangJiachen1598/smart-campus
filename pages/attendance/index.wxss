.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.month-selector {
  margin: -30rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-value {
  font-size: 28rpx;
  color: #1a73e8;
  font-weight: 500;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.stats-card {
  display: flex;
  align-items: center;
  margin: 0 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.rate-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: conic-gradient(#1a73e8 0deg calc(var(--rate, 85) * 3.6deg), #e0e0e0 calc(var(--rate, 85) * 3.6deg) 360deg);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.rate-circle::before {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
}

.circle-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rate-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a73e8;
}

.rate-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.stats-grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-left: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
}

.stat-item.normal {
  background: #e8f5e9;
}

.stat-item.late {
  background: #fff3e0;
}

.stat-item.leave {
  background: #e3f2fd;
}

.stat-item.absent {
  background: #ffebee;
}

.stat-item .stat-value {
  font-size: 36rpx;
  font-weight: 600;
}

.stat-item.normal .stat-value {
  color: #4caf50;
}

.stat-item.late .stat-value {
  color: #ff9800;
}

.stat-item.leave .stat-value {
  color: #1a73e8;
}

.stat-item.absent .stat-value {
  color: #f44336;
}

.stat-item .stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
}

.section {
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.attendance-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.attendance-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.attendance-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  flex-direction: column;
  width: 160rpx;
}

.item-date {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.item-week {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-center {
  flex: 1;
  margin: 0 20rpx;
}

.item-course {
  font-size: 28rpx;
  color: #333;
}

.item-right {
  display: flex;
  align-items: center;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-normal {
  background: #e8f5e9;
  color: #4caf50;
}

.status-late {
  background: #fff3e0;
  color: #ff9800;
}

.status-absent {
  background: #ffebee;
  color: #f44336;
}

.status-leave {
  background: #e3f2fd;
  color: #1a73e8;
}

.empty-tip {
  padding: 80rpx 0;
  text-align: center;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
}

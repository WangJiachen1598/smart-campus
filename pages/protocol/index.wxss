page {
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #1a73e8, #4285f4);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

.content {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a73e8;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1a73e8;
}

.section-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.section-content text {
  display: block;
  margin-bottom: 16rpx;
}

.indent {
  padding-left: 40rpx;
}

.indent text {
  padding-left: 20rpx;
}

.highlight {
  color: #1a73e8;
  font-weight: 500;
}

.footer {
  margin-top: 30rpx;
  text-align: center;
  padding: 40rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.footer-text {
  font-size: 26rpx;
  color: #999999;
}

.footer-contact {
  font-size: 28rpx;
  color: #1a73e8;
  margin-top: 16rpx;
}

.back-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #4285f4);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.back-btn::after {
  border: none;
}

.top-btn {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1a73e8, #4285f4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.4);
}

.top-btn text {
  color: #ffffff;
  font-size: 32rpx;
}

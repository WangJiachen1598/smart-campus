.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f5f5f5;
}

.camera-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  display: flex;
  flex-direction: column;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  font-size: 28rpx;
  color: #333;
  padding: 0;
  line-height: 1.5;
}

.textarea {
  font-size: 28rpx;
  color: #333;
  min-height: 120rpx;
  padding: 0;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.gender-options {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.gender-option.active {
  border-color: #1a73e8;
  background: rgba(26, 115, 232, 0.08);
  color: #1a73e8;
}

.btn-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

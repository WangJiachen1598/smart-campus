<view class="container">
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <image class="avatar" wx:if="{{form.avatar}}" src="{{form.avatar}}" mode="aspectFill"></image>
      <view class="avatar" wx:else style="width: 160rpx; height: 160rpx; border-radius: 50%; background: linear-gradient(135deg, #1a73e8, #0d47a1); display: flex; align-items: center; justify-content: center; color: white; font-size: 64rpx;">
        {{form.role === 'teacher' ? '👨‍🏫' : '👨‍🎓'}}
      </view>
      <view class="camera-icon">
        <text style="font-size: 24rpx;">📷</text>
      </view>
    </view>
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item" wx:if="{{form.role === 'student'}}">
      <text class="label">学号</text>
      <input class="input" placeholder="请输入学号" value="{{form.studentId}}" bindinput="onStudentIdInput" maxlength="10" type="number" />
    </view>

    <view class="form-item">
      <text class="label">班级</text>
      <input class="input" placeholder="请输入班级" value="{{form.className}}" bindinput="onClassNameInput" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onPhoneInput" maxlength="11" type="number" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <view class="gender-options">
        <view class="gender-option {{form.gender === 'male' ? 'active' : ''}}" bindtap="selectGender" data-gender="male">
          <text>男</text>
        </view>
        <view class="gender-option {{form.gender === 'female' ? 'active' : ''}}" bindtap="selectGender" data-gender="female">
          <text>女</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">个性签名</text>
      <textarea class="textarea" placeholder="请输入个性签名（选填）" value="{{form.signature}}" bindinput="onSignatureInput" maxlength="100" />
      <view class="char-count">{{form.signature.length}}/100</view>
    </view>
  </view>

  <view class="btn-section">
    <button class="btn btn-primary btn-block" bindtap="saveProfile" loading="{{saving}}">保存</button>
    <button class="btn btn-outline btn-block" bindtap="cancelEdit">取消</button>
  </view>
</view>

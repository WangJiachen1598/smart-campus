<view class="container">
  <view class="header">
    <text class="title">成绩查询</text>
  </view>

  <view class="semester-selector">
    <picker mode="selector" range="{{semesters}}" value="{{semesters.indexOf(currentSemester)}}" bindchange="onSemesterChange">
      <view class="picker">
        <text class="picker-label">学期：</text>
        <text class="picker-value">{{currentSemester}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{averageScore}}</text>
      <text class="stat-label">平均分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{gpa}}</text>
      <text class="stat-label">GPA</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{totalCredit}}</text>
      <text class="stat-label">总学分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{passCount}}</text>
      <text class="stat-label">及格数</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">成绩列表</text>
    </view>
    <view class="grades-table">
      <view class="table-header">
        <text class="col-course">课程</text>
        <text class="col-credit">学分</text>
        <text class="col-score">成绩</text>
      </view>
      <view class="table-body">
        <view class="table-row" wx:for="{{grades}}" wx:key="id">
          <view class="col-course">
            <text class="course-name">{{item.course}}</text>
            <text class="course-type">{{item.type}}</text>
          </view>
          <text class="col-credit">{{item.credit}}</text>
          <view class="col-score">
            <text class="score-tag score-{{getScoreClass(item.score)}}">{{item.score}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{grades.length === 0}}">
        <text>暂无成绩数据</text>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />

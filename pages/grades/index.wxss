.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.semester-selector {
  margin: -30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-value {
  font-size: 28rpx;
  color: #1a73e8;
  font-weight: 500;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.stats-card {
  display: flex;
  align-items: center;
  margin: 0 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #1a73e8;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #f0f0f0;
}

.section {
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.grades-table {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.table-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.table-header text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a73e8;
}

.col-course {
  flex: 3;
}

.col-credit {
  flex: 1;
  text-align: center;
}

.col-score {
  flex: 1;
  text-align: center;
}

.table-body {
  padding: 0 30rpx;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.course-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.course-type {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.score-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.score-excellent {
  background: #e8f5e9;
  color: #4caf50;
}

.score-good {
  background: #fff3e0;
  color: #ff9800;
}

.score-pass {
  background: #e3f2fd;
  color: #1a73e8;
}

.score-fail {
  background: #ffebee;
  color: #f44336;
}

.empty-tip {
  padding: 80rpx 0;
  text-align: center;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
}

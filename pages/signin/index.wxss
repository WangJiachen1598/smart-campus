.header-section {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  padding: 40rpx 30rpx;
}

.activity-info {
  margin-bottom: 40rpx;
}

.activity-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.activity-time,
.activity-location {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.sign-in-status {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.status-icon image {
  width: 56rpx;
  height: 56rpx;
}

.status-text {
  flex: 1;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.action-section {
  padding: 30rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  color: #fff;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #1a73e8;
  color: #1a73e8;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.btn-block {
  width: 100%;
}

.records-section {
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  margin: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.record-list {
  max-height: 600rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #e3f2fd;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.sign-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.sign-method {
  margin-left: 16rpx;
}

.method-tag {
  font-size: 22rpx;
  color: #1a73e8;
  background: #e3f2fd;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
}

<view class="container" wx:if="{{activity}}">
  <view class="activity-header">
    <view class="cover" style="background: linear-gradient(135deg, #1a73e8, #0d47a1); display: flex; align-items: center; justify-content: center;">
      <text style="font-size: 80rpx; color: #fff;">🎉</text>
    </view>
    <view class="header-overlay">
      <view class="activity-basic">
        <text class="activity-title">{{activity.title}}</text>
        <view class="tag" style="background: {{activity.statusColor}}15; color: {{activity.statusColor}};">
          {{activity.statusLabel}}
        </view>
      </view>
    </view>
  </view>

  <view class="content-section">
    <view class="info-card">
      <view class="info-row">
        <text class="info-icon-emoji">🕐</text>
        <text class="info-label">活动时间</text>
        <text class="info-value">{{activity.startTime}} - {{activity.endTime}}</text>
      </view>
      <view class="info-row">
        <text class="info-icon-emoji">📍</text>
        <text class="info-label">活动地点</text>
        <text class="info-value">{{activity.location}}</text>
      </view>
      <view class="info-row">
        <text class="info-icon-emoji">👥</text>
        <text class="info-label">报名人数</text>
        <text class="info-value">{{activity.participantCount}} 人</text>
      </view>
      <view class="info-row">
        <text class="info-icon-emoji">✅</text>
        <text class="info-label">签到人数</text>
        <text class="info-value">{{activity.signInCount}} 人</text>
      </view>
    </view>

    <view class="section-title">活动详情</view>
    <view class="description">
      <text>{{activity.content}}</text>
    </view>
  </view>

  <view class="footer-bar">
    <button class="btn {{!isRegistered ? 'btn-secondary' : 'btn-outline'}}" 
            bindtap="registerActivity" wx:if="{{!isSignedIn && activity.status !== 'finished'}}">
      {{isRegistered ? '已报名' : '立即报名'}}
    </button>
    <button class="btn btn-primary" 
            bindtap="goSignIn" 
            wx:if="{{isRegistered && !isSignedIn && activity.signInEnabled && activity.status === 'ongoing'}}">
      签到
    </button>
    <button class="btn btn-secondary disabled" 
            wx:if="{{isSignedIn}}">
      已签到
    </button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
</view>

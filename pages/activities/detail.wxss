.activity-header {
  position: relative;
  height: 400rpx;
}

.cover {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
}

.activity-basic {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.activity-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
  margin-right: 20rpx;
}

.content-section {
  padding: 30rpx;
  padding-bottom: 150rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.info-icon-emoji {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 20rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  text-align: right;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.description {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  color: #fff;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #1a73e8;
  color: #1a73e8;
}

.btn.disabled {
  background: #e0e0e0;
  color: #999;
}

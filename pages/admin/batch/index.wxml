<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'import' ? 'active' : ''}}" bindtap="switchTab" data-tab="import">
      <text class="tab-icon">📥</text>
      <text class="tab-name">批量导入</text>
    </view>
    <view class="tab-item {{currentTab === 'export' ? 'active' : ''}}" bindtap="switchTab" data-tab="export">
      <text class="tab-icon">📤</text>
      <text class="tab-name">批量导出</text>
    </view>
  </view>

  <!-- 导入内容 -->
  <view class="tab-content" wx:if="{{currentTab === 'import'}}">
    <view class="section">
      <view class="section-title">选择导入类型</view>
      <view class="type-grid">
        <view class="type-item {{importType === item.id ? 'active' : ''}}" 
              wx:for="{{dataTypes}}" 
              wx:key="id"
              bindtap="selectImportType" 
              data-type="{{item.id}}">
          <view class="type-icon">{{item.icon}}</view>
          <text class="type-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">下载模板</view>
      <view class="template-card" bindtap="downloadTemplate">
        <view class="template-icon">📄</view>
        <view class="template-info">
          <text class="template-name">{{currentTypeName}}模板</text>
          <text class="template-desc">点击下载，按格式填写数据</text>
        </view>
        <view class="template-arrow">›</view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">上传文件</view>
      <view class="upload-area" bindtap="chooseFile">
        <view class="upload-icon">📁</view>
        <text class="upload-text">{{fileList.length > 0 ? '已选择文件' : '点击选择文件'}}</text>
        <text class="upload-hint">支持 xlsx, xls 格式</text>
      </view>
      <view class="file-list" wx:if="{{fileList.length > 0}}">
        <view class="file-item" wx:for="{{fileList}}" wx:key="name">
          <text class="file-name">{{item.name}}</text>
          <view class="file-remove" bindtap="removeFile" data-index="{{index}}">×</view>
        </view>
      </view>
    </view>

    <view class="section">
      <button class="action-btn primary" bindtap="startImport" disabled="{{fileList.length === 0}}">
        开始导入
      </button>
    </view>

    <view class="section">
      <view class="section-title">导入历史</view>
      <view class="history-list">
        <view class="history-item" wx:for="{{importHistory}}" wx:key="id">
          <view class="history-icon success">✓</view>
          <view class="history-info">
            <text class="history-name">{{item.fileName}}</text>
            <text class="history-meta">{{item.time}} · 导入 {{item.count}} 条</text>
          </view>
          <text class="history-status success">成功</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 导出内容 -->
  <view class="tab-content" wx:if="{{currentTab === 'export'}}">
    <view class="section">
      <view class="section-title">选择导出类型</view>
      <view class="type-grid">
        <view class="type-item {{exportType === item.id ? 'active' : ''}}" 
              wx:for="{{dataTypes}}" 
              wx:key="id"
              bindtap="selectExportType" 
              data-type="{{item.id}}">
          <view class="type-icon">{{item.icon}}</view>
          <text class="type-name">{{item.name}}</text>
          <text class="type-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">导出设置</view>
      <view class="setting-item">
        <text class="setting-label">日期范围</text>
        <view class="date-pickers">
          <picker mode="date" value="{{dateRange.start}}" bindchange="onStartDateChange">
            <view class="date-picker">
              <text>{{dateRange.start}}</text>
            </view>
          </picker>
          <text class="date-separator">至</text>
          <picker mode="date" value="{{dateRange.end}}" bindchange="onEndDateChange">
            <view class="date-picker">
              <text>{{dateRange.end}}</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="setting-item">
        <text class="setting-label">导出格式</text>
        <view class="format-options">
          <view class="format-tag active">Excel (.xlsx)</view>
          <view class="format-tag">CSV</view>
        </view>
      </view>
    </view>

    <view class="section">
      <button class="action-btn primary" bindtap="exportData">
        导出选中数据
      </button>
      <button class="action-btn" bindtap="exportAll">
        导出全部数据
      </button>
    </view>

    <view class="section">
      <view class="section-title">导出历史</view>
      <view class="history-list">
        <view class="history-item" wx:for="{{exportHistory}}" wx:key="id">
          <view class="history-icon">📄</view>
          <view class="history-info">
            <text class="history-name">{{item.fileName}}</text>
            <text class="history-meta">{{item.time}} · {{item.size}}</text>
          </view>
          <view class="history-action" bindtap="downloadHistory" data-url="{{item.url}}">下载</view>
        </view>
      </view>
    </view>
  </view>
</view>

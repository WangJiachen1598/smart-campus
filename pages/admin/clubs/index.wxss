.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
}

.club-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.club-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.club-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.club-cover image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  font-size: 64rpx;
}

.club-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.club-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.club-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-active {
  background: rgba(76, 175, 80, 0.15);
  color: #4caf50;
}

.status-inactive {
  background: rgba(244, 67, 54, 0.15);
  color: #f44336;
}

.club-meta,
.club-leader,
.club-create {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.club-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
}

.action-btn.danger {
  background: #fff1f0;
  color: #ff4d4f;
}

.action-btn.success {
  background: rgba(76, 175, 80, 0.15);
  color: #4caf50;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  color: #999;
  gap: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
}

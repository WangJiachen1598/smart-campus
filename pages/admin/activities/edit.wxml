<view class="container">
  <view class="form-group">
    <view class="form-label">活动封面</view>
    <view class="image-upload" bindtap="chooseCoverImage">
      <image wx:if="{{coverImage}}" src="{{coverImage}}" class="preview-image" mode="aspectFill" />
      <view wx:else class="placeholder-area">
        <text class="placeholder-icon">📷</text>
        <text class="placeholder-text">点击上传封面</text>
      </view>
    </view>
    <view wx:if="{{coverImage}}" class="image-actions">
      <view class="action-btn" bindtap="previewCoverImage">预览</view>
      <view class="action-btn delete" bindtap="deleteCoverImage">删除</view>
    </view>
  </view>

  <view class="form-group">
    <view class="form-label">活动图片（可选）</view>
    <scroll-view class="image-grid" scroll-x="true">
      <view class="image-list">
        <view class="image-item" wx:for="{{activityImages}}" wx:key="index">
          <image class="grid-image" src="{{item}}" mode="aspectFill" />
          <view class="image-close" bindtap="deleteActivityImage" data-index="{{index}}">×</view>
        </view>
        <view class="image-add" wx:if="{{activityImages.length < 9}}" bindtap="chooseActivityImages">
          <text class="add-icon">+</text>
          <text class="add-text">添加</text>
        </view>
      </view>
    </scroll-view>
    <view class="image-tip">最多上传9张图片</view>
  </view>

  <view class="form-group">
    <view class="form-label">活动名称</view>
    <input class="form-input" value="{{title}}" placeholder="请输入活动名称" bindinput="onTitleChange" />
  </view>

  <view class="form-group">
    <view class="form-label">所属社团</view>
    <picker mode="selector" range="{{clubs}}" range-key="name" value="{{clubIndex}}" bindchange="onClubChange">
      <view class="form-picker">
        <text>{{clubIndex >= 0 ? clubs[clubIndex].name : '请选择社团'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="form-group">
    <view class="form-label">活动地点</view>
    <input class="form-input" value="{{location}}" placeholder="请输入活动地点" bindinput="onLocationChange" />
  </view>

  <view class="form-group">
    <view class="form-label">开始时间</view>
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="form-picker">
        <text>{{startDate || '请选择日期'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
      <view class="form-picker" style="margin-top: 15rpx;">
        <text>{{startTime || '请选择时间'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="form-group">
    <view class="form-label">结束时间</view>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="form-picker">
        <text>{{endDate || '请选择日期'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
      <view class="form-picker" style="margin-top: 15rpx;">
        <text>{{endTime || '请选择时间'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="form-group">
    <view class="form-label">活动描述</view>
    <textarea class="form-textarea" value="{{description}}" placeholder="请输入活动描述" bindinput="onDescriptionChange" />
  </view>

  <button class="save-btn" type="primary" bindtap="saveActivity">保存</button>
</view>
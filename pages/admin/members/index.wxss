.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1a73e8;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #1a73e8;
  border-radius: 3rpx;
}

.badge {
  background: #e53935;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
}

.member-list {
  padding: 20rpx 30rpx;
}

.member-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.member-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.student-id, .club-name {
  font-size: 24rpx;
  color: #666;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
}

.reject-reason {
  font-size: 24rpx;
  color: #e53935;
  margin-top: 8rpx;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 16rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-btn.approve {
  background: #e8f5e9;
  color: #388e3c;
}

.action-btn.reject {
  background: #ffebee;
  color: #e53935;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.status-tag.approved {
  background: #e8f5e9;
  color: #388e3c;
}

.status-tag.rejected {
  background: #ffebee;
  color: #e53935;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  color: #ccc;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

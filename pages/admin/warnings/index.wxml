<view class="container">
  <view class="header">
    <view class="header-title">异常预警</view>
  </view>

  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">预警总数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value warning">{{stats.attendance}}</text>
      <text class="stat-label">考勤预警</text>
    </view>
    <view class="stat-item">
      <text class="stat-value danger">{{stats.grade}}</text>
      <text class="stat-label">成绩预警</text>
    </view>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">
      <text>全部</text>
    </view>
    <view class="tab-item {{currentTab === 'attendance' ? 'active' : ''}}" data-tab="attendance" bindtap="switchTab">
      <text>考勤</text>
    </view>
    <view class="tab-item {{currentTab === 'grade' ? 'active' : ''}}" data-tab="grade" bindtap="switchTab">
      <text>成绩</text>
    </view>
  </view>

  <view class="warning-list">
    <view class="warning-item level-{{item.level}}" wx:for="{{filteredWarnings}}" wx:key="id">
      <view class="warning-header">
        <view class="warning-type">
          <text class="type-icon">{{item.typeIcon}}</text>
          <text class="type-text">{{item.typeName}}</text>
        </view>
        <view class="warning-level level-{{item.level}}">
          {{item.levelText}}
        </view>
      </view>
      <view class="warning-body">
        <view class="student-info">
          <text class="student-name">{{item.name}}</text>
          <text class="student-id">学号: {{item.studentId}}</text>
          <text class="class-name">{{item.className}}</text>
        </view>
        <view class="warning-desc">{{item.description}}</view>
        <view class="warning-count">异常次数: {{item.count}}次</view>
      </view>
      <view class="warning-actions">
        <view class="action-btn primary" bindtap="handleWarning" data-id="{{item.id}}">处理</view>
        <view class="action-btn" bindtap="viewDetail" data-id="{{item.id}}">详情</view>
        <view class="action-btn" bindtap="ignoreWarning" data-id="{{item.id}}">忽略</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredWarnings.length === 0}}">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">暂无预警信息</text>
    </view>
  </view>

  <view class="bottom-action">
    <button class="export-btn" bindtap="exportWarnings">导出预警记录</button>
  </view>
</view>

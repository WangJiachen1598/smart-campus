.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  padding: 30rpx;
  background: #1a73e8;
}

.header-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.stats-bar {
  display: flex;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.warning {
  color: #ff9800;
}

.stat-value.danger {
  color: #e53935;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1a73e8;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #1a73e8;
  border-radius: 3rpx;
}

.warning-list {
  padding: 20rpx 30rpx;
}

.warning-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.warning-item.level-danger {
  border-left: 8rpx solid #e53935;
}

.warning-item.level-warning {
  border-left: 8rpx solid #ff9800;
}

.warning-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.warning-type {
  display: flex;
  align-items: center;
}

.type-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.type-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.warning-level {
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.warning-level.level-danger {
  background: #ffebee;
  color: #e53935;
}

.warning-level.level-warning {
  background: #fff3e0;
  color: #ff9800;
}

.warning-body {
  padding: 24rpx 30rpx;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.student-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.student-id, .class-name {
  font-size: 24rpx;
  color: #999;
}

.warning-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.warning-count {
  font-size: 24rpx;
  color: #e53935;
}

.warning-actions {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.action-btn.primary {
  background: #1a73e8;
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.export-btn {
  background: #1a73e8;
  color: #fff;
  border-radius: 44rpx;
}

<view class="container">
  <view class="header">
    <view class="header-title">签到管理</view>
  </view>

  <view class="activity-list">
    <view class="section-title">选择活动查看签到情况</view>
    <view class="activity-item" wx:for="{{activities}}" wx:key="id" data-id="{{item.id}}" bindtap="selectActivity">
      <view class="activity-info">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-meta">
          <text class="meta-text">{{item.startTime}}</text>
          <text class="meta-text">{{item.location}}</text>
        </view>
      </view>
      <view class="activity-stats">
        <view class="stat-item">
          <text class="stat-value">{{item.signInCount}}</text>
          <text class="stat-label">已签到</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{item.participantCount}}</text>
          <text class="stat-label">参与人数</text>
        </view>
      </view>
      <view class="arrow-icon">></view>
    </view>

    <view class="empty-state" wx:if="{{activities.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无需要签到的活动</text>
    </view>
  </view>

  <view class="modal" wx:if="{{showDetail}}">
    <view class="modal-mask" bindtap="closeDetail"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">签到详情</text>
        <text class="modal-close" bindtap="closeDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="activity-detail">
          <view class="detail-title">{{selectedActivity.title}}</view>
          <view class="detail-info">
            <text>时间: {{selectedActivity.startTime}}</text>
            <text>地点: {{selectedActivity.location}}</text>
          </view>
          <view class="detail-stats">
            <view class="detail-stat">
              <text class="num">{{currentSignIns.length}}</text>
              <text class="label">已签到</text>
            </view>
            <view class="detail-stat">
              <text class="num">{{selectedActivity.participantCount - currentSignIns.length}}</text>
              <text class="label">未签到</text>
            </view>
          </view>
        </view>

        <view class="signin-list">
          <view class="signin-title">签到记录</view>
          <view class="signin-item" wx:for="{{currentSignIns}}" wx:key="id">
            <view class="signin-info">
              <text class="student-id">{{item.studentId}}</text>
              <text class="signin-time">{{item.signInTime}}</text>
            </view>
            <view class="signin-method">{{item.signInMethod}}</view>
          </view>
          <view class="empty-signin" wx:if="{{currentSignIns.length === 0}}">
            <text>暂无签到记录</text>
          </view>
        </view>

        <view class="action-btns">
          <button class="action-btn primary" bindtap="generateSignInCode">生成签到码</button>
          <button class="action-btn" bindtap="exportSignIn">导出记录</button>
        </view>
      </view>
    </view>
  </view>
</view>

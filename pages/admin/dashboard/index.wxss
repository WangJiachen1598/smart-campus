.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.navbar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: calc(var(--status-bar-height, 44rpx) + 88rpx);
  background: #1a73e8;
}

.navbar-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--status-bar-height, 44rpx);
  height: 88rpx;
}

.navbar-left {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: #fff;
  font-size: 28rpx;
}

.home-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.home-text {
  line-height: 1;
}

.navbar-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.navbar-right {
  width: 160rpx;
}

.container {
  padding: 30rpx;
  padding-bottom: 160rpx;
  padding-top: calc(var(--status-bar-height, 44rpx) + 88rpx + 30rpx);
  background: #f5f5f5;
  min-height: 100vh;
}

.filter-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.picker-view {
  flex: 1;
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #f0f4f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1a73e8;
}

.picker-arrow {
  font-size: 24rpx;
  color: #666;
}

.overview-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.overview-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.overview-card.warning {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.overview-card.warning .overview-value,
.overview-card.warning .overview-label {
  color: #fff;
}

.overview-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a73e8;
  margin-bottom: 12rpx;
}

.overview-label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.chart-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.bar-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.bar-container {
  width: 80rpx;
  height: 200rpx;
  background: #f0f4f8;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 100%;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  border-radius: 8rpx 8rpx 0 0;
}

.bar-value {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #1a73e8;
  font-weight: 600;
}

.pie-chart {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.pie-item {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 200rpx;
}

.pie-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.pie-label {
  font-size: 26rpx;
  color: #333;
  margin-right: 12rpx;
}

.pie-value {
  font-size: 24rpx;
  color: #666;
}

.warning-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fff8e1;
}

.warning-item.warning-danger {
  background: #ffebee;
}

.warning-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff9800;
  margin-top: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.warning-item.warning-danger .warning-dot {
  background: #f44336;
}

.warning-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.warning-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.warning-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.navbar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: calc(var(--status-bar-height, 44rpx) + 88rpx);
  background: #1a73e8;
}

.navbar-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--status-bar-height, 44rpx);
  height: 88rpx;
}

.navbar-left {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: #fff;
  font-size: 28rpx;
}

.home-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.home-text {
  line-height: 1;
}

.navbar-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.navbar-right {
  width: 160rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  padding-top: calc(var(--status-bar-height, 44rpx) + 88rpx);
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  padding: 40rpx 30rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.tab-bar {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  background: #fff;
  margin-top: 20rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
  font-weight: 500;
}

.dashboard-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 30rpx;
  margin-top: -20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-card.warning-card {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.stat-card.warning-card .stat-value,
.stat-card.warning-card .stat-label {
  color: #fff;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a73e8;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

.quick-actions, .recent-section {
  padding: 0 30rpx;
  margin-top: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-text {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.recent-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.recent-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1a73e8;
  margin-top: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.recent-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recent-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.recent-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 30rpx;
  background: #1a73e8;
}

.header-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.export-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #e3f2fd;
  border-color: #1a73e8;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.date-range {
  display: flex;
  align-items: center;
}

.date-input {
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  width: 180rpx;
  text-align: center;
}

.date-separator {
  margin: 0 16rpx;
  font-size: 24rpx;
  color: #999;
}

.format-tag {
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
}

.format-tag.active {
  background: #e3f2fd;
  color: #1a73e8;
}

.export-btn {
  margin-bottom: 20rpx;
  border-radius: 44rpx;
  background: #f5f5f5;
  color: #333;
}

.export-btn.primary {
  background: #1a73e8;
  color: #fff;
}

.history-list {
  margin-top: 10rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.history-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.history-meta {
  font-size: 24rpx;
  color: #999;
}

.history-action {
  font-size: 26rpx;
  color: #1a73e8;
}
